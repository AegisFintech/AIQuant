# ══════════════════════════════════════════════════════════════
#  AIQuant — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is git-ignored and will never be committed.
# ══════════════════════════════════════════════════════════════

# ── Hyperliquid (required for live trading) ───────────────────
# Your Ethereum private key for Hyperliquid mainnet execution.
# Generate one: python3 -c "from eth_account import Account; a=Account.create(); print(a.key.hex())"
# Fund your account at: https://app.hyperliquid.xyz
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# ── Backtest Settings (optional overrides) ────────────────────
# Default pair if not passed via CLI (e.g. BTCUSDT, ETHUSDT)
DEFAULT_PAIR=BTCUSDT

# Default number of days of history for backtesting
DEFAULT_DAYS=90

# Starting capital for backtests (USD)
BACKTEST_CAPITAL=100000

# ── Live Trading Settings (optional overrides) ────────────────
# Starting capital for live trading (USD)
LIVE_CAPITAL=10000

# Kelly fraction for position sizing (0.5 = Half-Kelly, recommended)
KELLY_FRACTION=0.5

# Poll interval for live trading loop (seconds)
POLL_INTERVAL_SEC=60

# Maximum position size as fraction of portfolio (0.25 = 25%)
MAX_POSITION_FRACTION=0.25

# Maximum daily loss before halting (fraction, 0.03 = 3%)
MAX_DAILY_LOSS=0.03

# Maximum drawdown before halting (fraction, 0.15 = 15%)
MAX_DRAWDOWN=0.15

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
