# ============================================================
# AIQuant Environment Configuration
# AegisFintech | BTCUSD HFT Statistical Arbitrage Framework
# ============================================================

# ------------------------------------------------------------
# HYPERLIQUID (Paper / Live Trading)
# ------------------------------------------------------------
# Generate a wallet: python3 -c "from eth_account import Account; a=Account.create(); print('KEY:', a.key.hex(), '\nADDR:', a.address)"
# Testnet faucet (requires mainnet activation): https://app.hyperliquid-testnet.xyz/drip
# Mainnet: https://app.hyperliquid.xyz
HYPERLIQUID_PRIVATE_KEY=your_ethereum_private_key_here
HYPERLIQUID_USE_TESTNET=true

# ------------------------------------------------------------
# BINANCE (Data Feed — Public API, no key needed for read-only)
# For higher rate limits on order book / private endpoints:
# Get keys at: https://www.binance.com/en/my/settings/api-management
# ------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ------------------------------------------------------------
# ON-CHAIN DATA (Free tiers)
# ------------------------------------------------------------
# Glassnode — on-chain metrics (hash rate, SOPR, MVRV, etc.)
# Free tier: https://studio.glassnode.com/settings/api
GLASSNODE_API_KEY=

# CryptoCompare — OHLCV, social sentiment, news
# Free tier: https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=

# ------------------------------------------------------------
# PAPER TRADING ENGINE (self-contained, no keys needed)
# ------------------------------------------------------------
PAPER_TRADING_INITIAL_CAPITAL=10000
PAPER_TRADING_KELLY_FRACTION=0.5
PAPER_TRADING_MAX_DRAWDOWN=0.15
PAPER_TRADING_DAILY_LOSS_LIMIT=0.05

# ------------------------------------------------------------
# BACKTEST SETTINGS
# ------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=100000
BACKTEST_TAKER_FEE=0.00035
BACKTEST_SLIPPAGE=0.0001

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
